# Скопіюй цей файл у .env і заповни своїми значеннями:
#   cp .env.example .env

# Hugging Face token для pyannote.audio (діаризація)
# Отримати на: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Ollama (якщо не на localhost)
OLLAMA_HOST=http://localhost:11434

# Для Windows: уникнення конфліктів OpenMP між torch і whisperx
KMP_DUPLICATE_LIB_OK=TRUE
